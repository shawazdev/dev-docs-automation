<div id="js-marquee" class="js-marquee" aria-hidden="true" role="presentation" tabindex="-1">
  <div class="js-marquee-track">
    <div class="js-marquee-item">BLACK FRIDAY LIVE NOW — UP TO 60% OFF SITEWIDE | No code needed. Discounts applied automatically.</div>
  </div>
