<div id="js-marquee" class="js-marquee" aria-hidden="true" role="presentation" tabindex="-1">
  <div class="js-marquee-track">
    <div class="js-marquee-item">30-DAY MONEY BACK GUARANTEE</div>
  </div>
</div>

<!-- CSS -->
<style>
    @font-face {
  font-family: 'MDSystemNarrow-Regular';
  src: url('/fonts/MDSystemNarrow-Regular.otf') format('opentype');
  font-weight: normal;
  font-style: normal;
}
:root{
  --js-marquee-height: 44px;
  --js-marquee-bg: #012a18;
  --js-marquee-color: #fff;
  --js-marquee-font-size:14px;
  --js-marquee-speed: 80; /* pixels per second */
}
.js-marquee{
  overflow:hidden;
  background:var(--js-marquee-bg);
  color:var(--js-marquee-color);
  height:var(--js-marquee-height);
  display:flex;
  align-items:center;
  padding:0 12px;
  box-sizing:border-box;
  font-family: 'MDSystemNarrow-Regular', sans-serif;
}
.js-marquee-track{
  display:flex;
  align-items:center;
  gap: 3rem;
  white-space:nowrap;
  will-change: transform;
}
.js-marquee-item{
  display:inline-block;
  font-weight:400;
  font-size:var(--js-marquee-font-size);
}
.js-marquee.paused .js-marquee-track { /* visual class to indicate pause */
  /* nothing needed; JS pauses movement */
}
/* Reduced motion fallback */
@media (prefers-reduced-motion: reduce){
  .js-marquee-track { transform: none !important; }
}
</style>

<!-- JS -->
<script>
(function(){
  const marquee = document.getElementById('js-marquee');
  const track = marquee.querySelector('.js-marquee-track');
  const item = marquee.querySelector('.js-marquee-item');

  // clone content until track width >= twice viewport width for smooth loop
  function populateClones(){
    // remove extra clones if any
    track.innerHTML = '';
    track.appendChild(item.cloneNode(true));
    let totalWidth = track.scrollWidth;
    const viewportWidth = marquee.clientWidth;
    // keep adding clones until total width > viewportWidth * 2
    while (totalWidth < viewportWidth * 2) {
      track.appendChild(item.cloneNode(true));
      totalWidth = track.scrollWidth;
    }
  }

  let lastTimestamp = null;
  let offset = 0;
  const speed = parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--js-marquee-speed')) || 80; // px/s
  let rafId = null;
  let running = true;

  function step(ts){
    if (!lastTimestamp) lastTimestamp = ts;
    const dt = (ts - lastTimestamp) / 1000;
    lastTimestamp = ts;
    if (running) {
      offset -= speed * dt;
      // loop: when offset < -half of content width, reset by +half
      const contentWidth = track.scrollWidth / 2; // because we duplicated to >=2x
      if (Math.abs(offset) >= contentWidth) offset += contentWidth;
      track.style.transform = `translateX(${offset}px)`;
    }
    rafId = requestAnimationFrame(step);
  }

  // pause on hover/focus
  marquee.addEventListener('mouseenter', ()=> running = false);
  marquee.addEventListener('mouseleave', ()=> running = true);
  marquee.addEventListener('focusin', ()=> running = false);
  marquee.addEventListener('focusout', ()=> running = true);

  // rebuild clones on resize
  let resizeTimer;
  window.addEventListener('resize', ()=>{
    cancelAnimationFrame(rafId);
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(()=> {
      populateClones();
      offset = 0;
      lastTimestamp = null;
      rafId = requestAnimationFrame(step);
    }, 150);
  });

  // init
  populateClones();
  rafId = requestAnimationFrame(step);

  // respect reduced motion
  const media = window.matchMedia('(prefers-reduced-motion: reduce)');
  if (media.matches) {
    running = false;
    track.style.transform = 'none';
    cancelAnimationFrame(rafId);
  }
})();
</script>
