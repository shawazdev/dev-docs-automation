{"sections":{"main":{"type":"main-page","disabled":true,"settings":{"content_width":"80ch"}},"wd_banner_q4nzpc":{"type":"wd-banner","settings":{"empty_mobile":false,"full_width":true,"enable_parallax":true,"title":"Go Big. Every Damn Day.","bolder_title":false,"title_tag":"h1","subtitle":"","uptitle":"","uptitle_tag":"h1","title_size":"h0","image_size":"auto","image":"shopify:\/\/shop_images\/SS25_Campaign_82.jpg","mobile_image":"shopify:\/\/shop_images\/SS25_Campaign_82.jpg","mobile_smaller_text":false,"mobile_full_height":false,"mobile_text_position":"place-self-center text-center","desktop_text_position":"sm:place-self-center sm:text-center","featured_product":"","featured_product_heading":"Featured product","text_color":"#ffffff","overlay_color":"#000000","overlay_opacity":0}},"wd_images_xYkGR8":{"type":"wd-images","blocks":{"image_BfQpRW":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/strongsize-big-and-tall-about-01_f6e6b35a-bd09-4a85-82f0-618c8ef95bd6.jpg","width":33}},"image_PQWdCx":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/strongsize-big-and-tall-about-03_f06f47a7-0871-4d82-ab53-562c21de83ae.jpg","width":38}},"image_xyFKjq":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/strongsize-big-and-tall-about-02_0c725e73-6d73-4c4a-8729-6efdd67c61d1.jpg","width":33}}},"block_order":["image_BfQpRW","image_PQWdCx","image_xyFKjq"],"settings":{"title":"Our Mission","subtitle":"<p>To empower big and tall men to embrace their size with confidence, through premium, perfectly fitted clothing that elevate everyday life.<\/p>"}},"wd_image_text_mBX3cw":{"type":"wd-image-text","settings":{"image":"shopify:\/\/shop_images\/strongsize-big-and-tall-our-story.jpg","image_above":"shopify:\/\/shop_images\/Strongsize-Crest-Green.svg","title":"Our Story","subtitle":"<p>Strongsize was built for the guys most brands ignore.<\/p><p>We don’t just size up. We start from scratch—designing every piece to fit the needs of men in XL to 8XL. That means longer lengths, more room where it counts, and cuts that move with you, not against you.<\/p><p>We launched with one mission: build the best damn t-shirt a big guy’s ever worn. Today, our vision is bigger—delivering premium basics that actually fit, feel good, and hold up. No inflated prices. No compromises.<\/p><p>This isn’t about chasing trends. It’s about giving big and tall men the essentials they’ve been missing. Gear that works for your size, your life, and your style.<\/p><p>Because your size shouldn’t be an afterthought. It should be the starting point.<\/p><p><strong>Strongsize. Built for Bigger. Made for Better.<\/strong><\/p>","position":"row"}},"wd_text_Gk7VNQ":{"type":"wd-text","disabled":true,"settings":{"text":"To build a brand and community that redefines how big and tall men see themselves—through better fit, better representation, and better options.","use_tag":"div"}},"wd_text_with_icons_d9DBcP":{"type":"wd-text-with-icons","blocks":{"item_Lji768":{"type":"item","settings":{"icon":"picto-coupon","custom_icon":"shopify:\/\/shop_images\/Fit-Big-Tall.png","mobile_icon_width":52,"icon_width":100,"icon_background_type":"none","icon_background":"","icon_color":"","title":"MADE FOR BIG & TALL","content":""}},"item_3YRARj":{"type":"item","settings":{"icon":"picto-coupon","custom_icon":"shopify:\/\/shop_images\/Feature-Crisp-Collar.png","mobile_icon_width":52,"icon_width":100,"icon_background_type":"none","icon_background":"","icon_color":"","title":"PREMIUM QUALITY","content":""}},"item_yGbBJp":{"type":"item","settings":{"icon":"picto-coupon","custom_icon":"shopify:\/\/shop_images\/Fabric-4-Way-Stretch.png","mobile_icon_width":52,"icon_width":100,"icon_background_type":"none","icon_background":"","icon_color":"","title":"FREEDOM TO MOVE","content":""}},"item_agYa9J":{"type":"item","settings":{"icon":"picto-coupon","custom_icon":"shopify:\/\/shop_images\/Feature-Built-Strong.png","mobile_icon_width":52,"icon_width":100,"icon_background_type":"none","i