########################################
### GLOBAL DEFAULT RULES (Shopify)
########################################
User-agent: *
Disallow: /a/downloads/-/*
Disallow: /admin
Disallow: /cart
Disallow: /orders
Disallow: /checkouts/
Disallow: /checkout
Disallow: /*preview_theme_id*
Disallow: /*preview_script_id*
Disallow: /carts
Disallow: /account
Disallow: /search
Disallow: /sf_private_access_tokens
Disallow: /.well-known/shopify/monorail
Disallow: /cdn/wpm/*.js
Disallow: /apple-app-site-association

# Prevent unwanted Shopify dynamic filter URLs
Disallow: /collections/*sort_by*
Disallow: /*/collections/*sort_by*
Disallow: /collections/*+*
Disallow: /collections/*%2B*
Disallow: /collections/*%2b*
Disallow: /*/collections/*+*
Disallow: /*/collections/*%2B*
Disallow: /*/collections/*%2b*
Disallow: */collections/*filter*&*filter*

# Blog filter duplicates
Disallow: /blogs/*+*
Disallow: /blogs/*%2B*
Disallow: /blogs/*%2b*
Disallow: /*/blogs/*+*
Disallow: /*/blogs/*%2B*
Disallow: /*/blogs/*%2b*

# Shopify dynamic recommendations
Disallow: /recommendations/products
Disallow: /*/recommendations/products

# Shopify remote-render ID URLs
Disallow: /products/*-[a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9]-remote
Disallow: /*/products/*-[a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9]-remote
Disallow: /collections/*/products/*-[a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9]-remote
Disallow: /*/collections/*/products/*-[a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9]-remote


########################################
### 🟢 STRONGSIZE FIX FOR SEMRUSH ISSUES
### Prevents canonical errors from pages
### that redirect or DO NOT EXIST
########################################

# Block ONLY broken / non-existent canonical roots 
# Example: /products/motion (does not exist)
Disallow: /products/motion$
Disallow: /products/motion-$

# Block automatic “base handles” that have no matching PDP
Disallow: /products/*-$


