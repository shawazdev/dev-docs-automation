{%- unless section.settings.full_width -%}
  {%- render 'section-spacing-collapsing' -%}
{%- endunless -%}

<style>
    #shopify-section-{{ section.id }} {
      {%- if section.settings.full_width -%}
        --section-outer-spacing-block: 0;
      {%- endif -%}

      --content-over-media-overlay: {{ section.settings.overlay_color.rgb }} / {{ section.settings.overlay_opacity | divided_by: 100.0 }};

      {%- if section.settings.allow_transparent_header -%}
        margin-block-start: calc(-1 * var(--header-height) * var(--section-is-first));
      {%- endif -%}
    }

    {%- unless section.settings.full_width -%}
      #shopify-section-{{ section.id }}:first-child .section[allow-transparent-header] {
        padding-block-start: max(var(--section-inner-max-spacing-block), var(--header-height));
      }
    {%- endunless -%}

    /* Hide mobile video on desktop */
    #shopify-section-{{ section.id }} .mobile-video {
      display: none;
    }

    /* Show mobile video on mobile, hide desktop video */
    @media screen and (max-width: 749px) {
      #shopify-section-{{ section.id }} .desktop-video {
        display: none;
      }
      #shopify-section-{{ section.id }} .mobile-video {
        display: block;
      }
    }

    /* Content position (horizontal placement) */
    #shopify-section-{{ section.id }} .video-content-wrapper {
      text-align: {{ section.settings.text_alignment }};
    }

    #shopify-section-{{ section.id }} .video-content-wrapper.position-left {
      justify-self: start;
      margin-right: auto;
    }

    #shopify-section-{{ section.id }} .video-content-wrapper.position-center {
      justify-self: center;
      margin-left: auto;
      margin-right: auto;
    }

    #shopify-section-{{ section.id }} .video-content-wrapper.position-right {
      justify-self: end;
      margin-left: auto;
    }

    /* Text alignment within content block */
    #shopify-section-{{ section.id }} .video-content-wrapper.align-left {
      align-items: flex-start;
      text-align: left;
    }

    #shopify-section-{{ section.id }} .video-content-wrapper.align-center {
      align-items: center;
      text-align: center;
    }

    #shopify-section-{{ section.id }} .video-content-wrapper.align-right {
      align-items: flex-end;
      text-align: right;
    }

    /* Custom typography for blocks */
    {%- for block in section.blocks -%}
      {%- if block.type == 'subheading' -%}
        #block-{{ block.id }} {
          font-size: {{ block.settings.font_size }}px;
          font-family: {{ block.settings.font_family }};
          font-weight: {{ block.settings.font_weight }};
        }
      {%- elsif block.type == 'heading' -%}
        #block-{{ block.id }} {
          font-size: {{ block.settings.font_size }}px;
          font-family: {{ block.settings.font_family }};
          font-weight: {{ block.settings.font_weight }};
        }
      {%- elsif block.type == 'richtext' -%}
        #block-{{ block.id }} {
          font-size: {{ block.settings.font_size }}px;
          font-family: {{ block.settings.font_family }};
          font-weight: {{ block.settings.font_weight }};
        }
      {%- endif -%}
    {%- endfor -%}

    /* Custom button spacing */
    #shopify-section-{{ section.id }} .video-button-group {
      display: flex;
      gap: 1rem;
      margin-top: 2rem;
      flex-wrap: wrap;
    }

    #shopify-section-{{ section.id }} .video-button-group.align-left {
      justify-content: flex-start;
    }
 #shopify-section-{{ section.id }}  .video-button-group.align-center a {
    text-transform: uppercase;
}
    #shopify-section-{{ section.id }} .video-button-group.align-center {
      justify-content: center;
    }

    #shopify-section-{{ section.id }} .video-button-group.align-right {
      justify-content: flex-end;
    }
    #shopify-section-{{ section.id }} .button-without-arrow.primary,
    #shopify-section-{{ section.id }} .button-with-arrow.primary{
      background: #052b1b;
      color: #fff;
      line-height: 1;
      border: 1px solid #052b1b;
      border-radius: 10px;
      transition: .3s;
      font-weight: normal;
      font-family: "MDSystemNarrow-Medium", sans-serif;
    }
     #shopify-section-{{ section.id }} .button-without-arrow.secondary,
    #shopify-section-{{ section.id }} .button-with-arrow.secondary{
      color: #052b1b;
      border: 1px solid #052b1b;
      background: #fff;
      line-height: 1;
      border-radius: 10px;
      transition: .3s;
      font-weight: normal;
      font-family: "MDSystemNarrow-Medium", sans-serif;
    }
  #shopify-section-{{ section.id }} .size-sm {
    padding: 6px 16px;
    font-size: 13px;
  }

  #shopify-section-{{ section.id }} .size-base {
    padding: 10px 22px;
    font-size: 15px;
  }

  #shopify-section-{{ section.id }} .size-lg {
    padding: 14px 30px;
    font-size: 17px;
  }

  #shopify-section-{{ section.id }} .size-xl {
    padding: 18px 40px;
    font-size: 19px;
  }

    /* Button with arrow icon */
    #shopify-section-{{ section.id }} .button-with-arrow {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
    }

    #shopify-section-{{ section.id }} .button-with-arrow svg {
     width: 50px;
    height: 50px;
    padding-top: 7px;
    }
    #shopify-section-{{ section.id }} .button-with-arrow.primary svg{
      fill: white;
    }
    #shopify-section-{{ section.id }} .button-with-arrow.secondary svg{
      fill: #052b1b;
    }
  #shopify-section-{{ section.id }}   a.button-with-arrow.size-lg {
     gap: 0px !important;
    padding: 2px 8px 2px 20px !important;
    text-transform: uppercase;
}
 #shopify-section-{{ section.id }}  a.button-with-arrow.size-xl {
    padding: 4px 10px 5px 25px !important;
    font-size: 19px;
    gap: 2px !important;
    text-transform: uppercase;
}
#shopify-section-{{ section.id }} a.button-with-arrow.size-base {
    gap: 0px !important;
    padding: 0px 5px 0px 17px !important;
    text-transform: uppercase;
}
#shopify-section-{{ section.id }} a.button-with-arrow.size-sm {
    gap: 0px !important;
    padding: 0px 5px 0px 19px !important;
    text-transform: uppercase;
}
</style>

<div
  {% render 'section-properties' %}
  {% if section.settings.allow_transparent_header %}
    allow-transparent-header
  {% endif %}
>
  {%- capture class -%}content-over-media {% if section.settings.video_size != 'auto' %}content-over-media--{{ section.settings.video_size }}{% endif %} {% if section.settings.full_width %}full-bleed{% else %}shadow-block rounded-lg{% endif %}{%- endcapture -%}

  <div {% render 'surface', class: class, text_color: section.settings.text_color %}>
    {%- comment -%} Desktop Video {%- endcomment -%}
    {%- capture desktop_poster -%}
      {%- assign poster_image = section.settings.poster | default: section.settings.video.preview_image -%}

      {%- if section.settings.autoplay == false and poster_image != blank -%}
        {%- capture sizes -%}{% if section.settings.full_width %}100vw{% else %}(max-width: 740px) calc(100vw - 40px), (max-width: 999px) calc(100vw - 64px), min({{ settings.page_width }}px, 100vw - 96px){% endif %}{%- endcapture -%}
        {{- poster_image | image_url: width: poster_image.width | image_tag: loading: 'lazy', sizes: sizes, widths: '200,300,400,500,600,700,800,900,1000,1200,1400,1600,1800,2000,2200,2400,2600,2800,3000,3200' -}}
      {%- endif -%}
    {%- endcapture -%}

    {%- if section.settings.video -%}
      <video-media
        class="desktop-video"
        {% if section.settings.autoplay %}
          autoplay
        {% endif %}
      >
        {%- if section.settings.autoplay -%}
          {%- assign show_controls = false -%}
        {%- else -%}
          {%- assign show_controls = true -%}
        {%- endif -%}

        {{-
          section.settings.video
          | video_tag:
            playsinline: true,
            preload: 'metadata',
            muted: section.settings.autoplay,
            loop: section.settings.autoplay,
            controls: show_controls,
            image_size: '800x'
        -}}
        {{- desktop_poster -}}
      </video-media>
    {%- else -%}
      <video-media
        class="desktop-video"
        host="{{ section.settings.external_video_url.type }}"
        {% if section.settings.autoplay %}
          autoplay class="pointer-events-none"
        {% endif %}
      >
        {{- desktop_poster -}}

        <template>
          {%- if section.settings.external_video_url.type == 'youtube' -%}
            <iframe
              src="https://www.youtube.com/embed/{{ section.settings.external_video_url.id }}?playsinline=1&{% if section.settings.autoplay %}autoplay=1&controls=0&mute=1&loop=1&{% endif %}playlist={{ section.settings.external_video_url.id }}&enablejsapi=1&rel=0&modestbranding=1&origin={{ 'https://' | append: request.host | url_encode }}"
              allow="autoplay; encrypted-media"
              allowfullscreen="allowfullscreen"
            ></iframe>
          {%- elsif section.settings.external_video_url.type == 'vimeo' -%}
            <iframe
              src="https://player.vimeo.com/video/{{ section.settings.external_video_url.id }}?autopause=1&{% if section.settings.autoplay %}background=1&autoplay=1&loop=1&muted=1&{% endif %}transparent=0&responsive=1&portrait=0&title=0&byline=0&color={{ settings.text_color | remove_first: '#' }}"
              allow="autoplay; encrypted-media;"
              allowfullscreen="allowfullscreen"
            ></iframe>
          {%- endif -%}
        </template>
      </video-media>
    {%- endif -%}

    {%- comment -%} Mobile Video {%- endcomment -%}
    {%- assign use_mobile_video = false -%}
    {%- if section.settings.mobile_video != blank or section.settings.mobile_external_video_url != blank -%}
      {%- assign use_mobile_video = true -%}
    {%- endif -%}

    {%- if use_mobile_video -%}
      {%- capture mobile_poster -%}
        {%- assign mobile_poster_image = section.settings.mobile_poster | default: section.settings.mobile_video.preview_image -%}

        {%- if section.settings.autoplay == false and mobile_poster_image != blank -%}
          {%- capture sizes -%}100vw{%- endcapture -%}
          {{- mobile_poster_image | image_url: width: mobile_poster_image.width | image_tag: loading: 'lazy', sizes: sizes, widths: '200,300,400,500,600,700,800,900,1000,1200,1400,1600' -}}
        {%- endif -%}
      {%- endcapture -%}

      {%- if section.settings.mobile_video -%}
        <video-media
          class="mobile-video"
          {% if section.settings.autoplay %}
            autoplay
          {% endif %}
        >
          {%- if section.settings.autoplay -%}
            {%- assign show_controls = false -%}
          {%- else -%}
            {%- assign show_controls = true -%}
          {%- endif -%}

          {{-
            section.settings.mobile_video
            | video_tag:
              playsinline: true,
              preload: 'metadata',
              muted: section.settings.autoplay,
              loop: section.settings.autoplay,
              controls: show_controls,
              image_size: '800x'
          -}}
          {{- mobile_poster -}}
        </video-media>
      {%- elsif section.settings.mobile_external_video_url != blank -%}
        <video-media
          class="mobile-video"
          host="{{ section.settings.mobile_external_video_url.type }}"
          {% if section.settings.autoplay %}
            autoplay class="pointer-events-none"
          {% endif %}
        >
          {{- mobile_poster -}}

          <template>
            {%- if section.settings.mobile_external_video_url.type == 'youtube' -%}
              <iframe
                src="https://www.youtube.com/embed/{{ section.settings.mobile_external_video_url.id }}?playsinline=1&{% if section.settings.autoplay %}autoplay=1&controls=0&mute=1&loop=1&{% endif %}playlist={{ section.settings.mobile_external_video_url.id }}&enablejsapi=1&rel=0&modestbranding=1&origin={{ 'https://' | append: request.host | url_encode }}"
                allow="autoplay; encrypted-media"
                allowfullscreen="allowfullscreen"
              ></iframe>
            {%- elsif section.settings.mobile_external_video_url.type == 'vimeo' -%}
              <iframe
                src="https://player.vimeo.com/video/{{ section.settings.mobile_external_video_url.id }}?autopause=1&{% if section.settings.autoplay %}background=1&autoplay=1&loop=1&muted=1&{% endif %}transparent=0&responsive=1&portrait=0&title=0&byline=0&color={{ settings.text_color | remove_first: '#' }}"
                allow="autoplay; encrypted-media;"
                allowfullscreen="allowfullscreen"
              ></iframe>
            {%- endif -%}
          </template>
        </video-media>
      {%- endif -%}
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="video-content-wrapper position-{{ section.settings.content_position }} align-{{ section.settings.text_alignment }}">
        <div class="prose">
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'play' -%}
                {%- unless section.settings.autoplay -%}
                  <button class="video-play-button" type="button" {{ block.shopify_attributes }}>
                    <span class="sr-only">{{ 'general.accessibility.play_video' | t }}</span>
                    {%- render 'icon' with 'play-button', width: 48, height: 48 -%}
                  </button>
                {%- endunless -%}

              {%- when 'subheading' -%}
                {%- if block.settings.text != blank -%}
                  <p id="block-{{ block.id }}" {{ block.shopify_attributes }}>{{ block.settings.text | escape }}</p>
                {%- endif -%}

              {%- when 'heading' -%}
                {%- if block.settings.text != blank -%}
                  <p id="block-{{ block.id }}" class="{{ block.settings.heading_tag }}" {{ block.shopify_attributes }}>
                    {{ block.settings.text | escape }}
                  </p>
                {%- endif -%}

              {%- when 'richtext' -%}
                {%- if block.settings.content != blank -%}
                  <div id="block-{{ block.id }}" {{ block.shopify_attributes }}>
                    {{- block.settings.content -}}
                  </div>
                {%- endif -%}
            {%- endcase -%}
          {%- endfor -%}

          {%- comment -%} Button Group - Primary and Secondary {%- endcomment -%}
          {%- assign has_buttons = false -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'button' and block.settings.text != blank -%}
              {%- assign has_buttons = true -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}

          {%- if has_buttons -%}
            <div class="video-button-group align-{{ section.settings.text_alignment }}">
              {%- for block in section.blocks -%}
                {%- if block.type == 'button' and block.settings.text != blank -%}
                  {%- assign button_has_icon = false -%}
                  {%- if block.settings.button_type == 'primary_with_icon'
                    or block.settings.button_type == 'secondary_with_icon'
                  -%}
                    {%- assign button_has_icon = true -%}
                  {%- endif -%}

                  {%- assign button_style = 'primary' -%}
                  {%- if block.settings.button_type == 'secondary_with_icon'
                    or block.settings.button_type == 'secondary_without_icon'
                  -%}
                    {%- assign button_style = 'secondary' -%}
                  {%- endif -%}

                  {%- if button_has_icon -%}
                    <a
                      href="{{ block.settings.url }}"
                      class="button-with-arrow {{ button_style }} size-{{ block.settings.size }}"
                      {{ block.shopify_attributes }}
                    >
                      <span>{{ block.settings.text }}</span>
                     <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 125" x="0px" y="0px"><path d="M79.82,51H20.25a1,1,0,1,1,0-2H79.82a1,1,0,0,1,0,2Z"/><path d="M80.25,51a1,1,0,0,1-.71-.3l-29.79-30a1,1,0,0,1,1.42-1.41L81,49.3a1,1,0,0,1-.71,1.7Z"/><path d="M50.46,81a1,1,0,0,1-.71-1.7l29.79-30A1,1,0,1,1,81,50.7l-29.79,30A1,1,0,0,1,50.46,81Z"/>
</svg>
                    </a>
                  {%- else -%}
                    <a
                      href="{{ block.settings.url }}"
                      class="button-without-arrow {{ button_style }} size-{{ block.settings.size }}"
                      {{ block.shopify_attributes }}
                    >
                      <span>{{ block.settings.text }}</span>
                    </a>
                  {%- endif -%}
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "WD Hero Video",
  "class": "shopify-section--video",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "paragraph",
      "content": "For best visual results and avoid platform branding, use a MP4 file."
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "allow_transparent_header",
      "label": "Allow transparent header",
      "info": "This setting only applies when this section is the first one.",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "info": "Video are muted to allow autoplay. For best results, do not add any content on top of the video when autoplay is enabled.",
      "default": false
    },
    {
      "type": "select",
      "id": "video_size",
      "label": "Video size",
      "options": [
        {
          "value": "auto",
          "label": "16/9 (recommended)"
        },
        {
          "value": "sm",
          "label": "Small"
        },
        {
          "value": "md",
          "label": "Medium"
        },
        {
          "value": "lg",
          "label": "Large"
        },
        {
          "value": "fill",
          "label": "Fill screen"
        }
      ],
      "default": "auto"
    },
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Content position",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center",
      "info": "Horizontal position of content block"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center",
      "info": "Text alignment within content block"
    },
    {
      "type": "header",
      "content": "Desktop Video"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Desktop video",
      "info": "Replaces external video if both are set."
    },
    {
      "type": "video_url",
      "id": "external_video_url",
      "accept": ["vimeo", "youtube"],
      "label": "Desktop video URL",
      "default": "https://www.youtube.com/watch?v=_9VUPq3SxOc"
    },
    {
      "type": "image_picker",
      "id": "poster",
      "label": "Desktop poster image",
      "info": "3200 x 1600px .jpg recommended. Poster is not visible when autoplay is enabled."
    },
    {
      "type": "header",
      "content": "Mobile Video"
    },
    {
      "type": "paragraph",
      "content": "Optional: Add a separate video optimized for mobile devices. If left empty, the desktop video will be used."
    },
    {
      "type": "video",
      "id": "mobile_video",
      "label": "Mobile video",
      "info": "Replaces external mobile video if both are set."
    },
    {
      "type": "video_url",
      "id": "mobile_external_video_url",
      "accept": ["vimeo", "youtube"],
      "label": "Mobile video URL"
    },
    {
      "type": "image_picker",
      "id": "mobile_poster",
      "label": "Mobile poster image",
      "info": "1200 x 1600px .jpg recommended (portrait). Poster is not visible when autoplay is enabled."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "play",
      "name": "Play button",
      "limit": 1,
      "settings": [
        {
          "type": "paragraph",
          "content": "Play button is hidden when autoplay is enabled."
        }
      ]
    },
    {
      "type": "subheading",
      "name": "Subheading",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Subheading"
        },
        {
          "type": "range",
          "id": "font_size",
          "label": "Font size",
          "min": 12,
          "max": 72,
          "step": 1,
          "unit": "px",
          "default": 16
        },
        {
          "type": "select",
          "id": "font_family",
          "label": "Font family",
          "options": [
            {
              "value": "MDSystemNarrow-Medium, sans-serif",
              "label": "MDSystemNarrow-Medium"
            },
            {
              "value": "MDSystemNarrow-Regular, sans-serif",
              "label": "MDSystemNarrow-Regular"
            },
            {
              "value": "MDSystem-Regular, serif",
              "label": "MDSystem-Regular"
            },
            {
              "value": "MDSystem-SemiBold, serif",
              "label": "MDSystem-SemiBold"
            }
          ],
          "default": "MDSystemNarrow-Medium, sans-serif"
        },
        {
          "type": "select",
          "id": "font_weight",
          "label": "Font weight",
          "options": [
            {
              "value": "300",
              "label": "Light"
            },
            {
              "value": "400",
              "label": "Normal"
            },
            {
              "value": "500",
              "label": "Medium"
            },
            {
              "value": "600",
              "label": "Semi Bold"
            },
            {
              "value": "700",
              "label": "Bold"
            },
            {
              "value": "800",
              "label": "Extra Bold"
            }
          ],
          "default": "700"
        }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Heading"
        },
        {
          "type": "select",
          "id": "heading_tag",
          "label": "Style",
          "options": [
            {
              "value": "h0",
              "label": "H0"
            },
            {
              "value": "h1",
              "label": "H1"
            },
            {
              "value": "h2",
              "label": "H2"
            },
